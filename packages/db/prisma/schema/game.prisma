model Activity {
  id                       String    @id @default(cuid())
  name                     String
  status                   String    @default("SETUP")
  startedAt                DateTime?
  endedAt                  DateTime?
  timeLimitMinutes         Int?
  maxTeams                 Int       @default(4)
  funFactGuessAttempts     Int       @default(2)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("activity")
}

model Player {
  id                       String                 @id @default(cuid())
  name                     String
  icon                     String?
  authUserId               String?                @unique
  authUser                 User?                  @relation(fields: [authUserId], references: [id], onDelete: SetNull)
  teamId                   String?
  team                     Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  isCheckedIn              Boolean                @default(false)
  scannedAttempts          ClaimAttempt[]         @relation("ScannedByPlayer")
  funFacts                 PlayerFunFact[]
  funFactChallengeGuesses  TeamFunFactChallenge[] @relation("LastFunFactGuess")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([teamId])
  @@index([authUserId])
  @@map("player")
}

model Team {
  id                    String                    @id @default(cuid())
  name                  String                    @unique
  joinCode              String                    @unique
  color                 String?
  icon                  String?
  signalBoostBalance    Int                       @default(2)
  players               Player[]
  assignments           TeamAstronautAssignment[]
  attempts              ClaimAttempt[]
  claims                TeamClaim[]
  hintReveals           TeamLocationHintReveal[]
  signalBoostLedger     SignalBoostLedger[]
  funFactChallenges     TeamFunFactChallenge[]
  funFactChallengeState TeamFunFactChallengeState?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@map("team")
}

model PlayerFunFact {
  id             String                 @id @default(cuid())
  playerId       String
  player         Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)
  factOrder      Int
  text           String
  challenges     TeamFunFactChallenge[]
  currentForTeam TeamFunFactChallengeState[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([playerId, factOrder])
  @@index([playerId])
  @@map("player_fun_fact")
}

model TeamFunFactChallenge {
  id                  String        @id @default(cuid())
  teamId              String
  team                Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerFunFactId     String
  playerFunFact       PlayerFunFact @relation(fields: [playerFunFactId], references: [id], onDelete: Cascade)
  status              String        @default("ACTIVE")
  attemptsUsed        Int           @default(0)
  lastGuessedPlayerId String?
  lastGuessedPlayer   Player?       @relation("LastFunFactGuess", fields: [lastGuessedPlayerId], references: [id], onDelete: SetNull)
  lastAttemptAt       DateTime?
  completedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([teamId, playerFunFactId])
  @@index([teamId])
  @@index([playerFunFactId])
  @@index([status])
  @@index([lastGuessedPlayerId])
  @@map("team_fun_fact_challenge")
}

model TeamFunFactChallengeState {
  id                 String        @id @default(cuid())
  teamId             String        @unique
  team               Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  currentFunFactId   String?
  currentFunFact     PlayerFunFact? @relation(fields: [currentFunFactId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([currentFunFactId])
  @@map("team_fun_fact_challenge_state")
}

model Astronaut {
  id          String                    @id @default(cuid())
  name        String
  code        String                    @unique
  description String?
  hint        String?
  active      Boolean                   @default(true)
  assignments TeamAstronautAssignment[]
  attempts    ClaimAttempt[]
  claims      TeamClaim[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([code])
  @@index([active])
  @@map("astronaut")
}

model TeamAstronautAssignment {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  astronautId String
  astronaut   Astronaut @relation(fields: [astronautId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([teamId, astronautId])
  @@index([teamId])
  @@index([astronautId])
  @@map("team_astronaut_assignment")
}

model ClaimAttempt {
  id                String     @id @default(cuid())
  teamId            String
  team              Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  astronautId       String
  astronaut         Astronaut  @relation(fields: [astronautId], references: [id], onDelete: Cascade)
  scannedByPlayerId String
  scannedByPlayer   Player     @relation("ScannedByPlayer", fields: [scannedByPlayerId], references: [id])
  status            String     @default("PENDING_PHOTO")
  taskPrompt        String
  imageUrl          String?
  imageBlobName     String?
  imageMimeType     String?
  imageSizeBytes    Int?
  aiPassed          Boolean?
  aiConfidence      Float?
  aiFeedback        String?
  aiRawResponse     String?
  createdAt         DateTime   @default(now())
  submittedAt       DateTime?
  reviewedAt        DateTime?
  expiresAt         DateTime?
  claim             TeamClaim?

  @@index([teamId])
  @@index([astronautId])
  @@index([scannedByPlayerId])
  @@index([status])
  @@index([expiresAt])
  @@map("claim_attempt")
}

model TeamClaim {
  id                    String       @id @default(cuid())
  teamId                String
  team                  Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  astronautId           String
  astronaut             Astronaut    @relation(fields: [astronautId], references: [id], onDelete: Cascade)
  claimAttemptId        String       @unique
  claimAttempt          ClaimAttempt @relation(fields: [claimAttemptId], references: [id], onDelete: Cascade)
  claimedAt             DateTime     @default(now())
  claimedElapsedSeconds Int?

  @@unique([teamId, astronautId])
  @@index([teamId])
  @@index([astronautId])
  @@map("team_claim")
}

model LocationHint {
  id             String                   @id @default(cuid())
  title          String?
  description    String?
  active         Boolean                  @default(true)
  sortOrder      Int                      @default(0)
  imageUrl       String?
  imageBlobName  String?
  imageMimeType  String?
  imageSizeBytes Int?
  reveals        TeamLocationHintReveal[]
  ledgerEntries  SignalBoostLedger[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([active])
  @@index([sortOrder])
  @@map("location_hint")
}

model TeamLocationHintReveal {
  id             String       @id @default(cuid())
  teamId         String
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  locationHintId String
  locationHint   LocationHint @relation(fields: [locationHintId], references: [id], onDelete: Cascade)
  revealLevel    Int          @default(0)
  lastSpentAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([teamId, locationHintId])
  @@index([teamId])
  @@index([locationHintId])
  @@map("team_location_hint_reveal")
}

model SignalBoostLedger {
  id             String        @id @default(cuid())
  teamId         String
  team           Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  locationHintId String?
  locationHint   LocationHint? @relation(fields: [locationHintId], references: [id], onDelete: SetNull)
  claimId        String?
  type           String
  delta          Int
  balanceAfter   Int
  note           String?
  createdAt      DateTime      @default(now())

  @@index([teamId])
  @@index([locationHintId])
  @@index([type])
  @@index([createdAt])
  @@map("signal_boost_ledger")
}
