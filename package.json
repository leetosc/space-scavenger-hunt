{
  "name": "space-scavenger-hunt",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.9",
      "@types/express": "^5.0.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @space-scavenger-hunt/db db:push",
    "db:studio": "turbo -F @space-scavenger-hunt/db db:studio",
    "db:generate": "turbo -F @space-scavenger-hunt/db db:generate",
    "db:migrate": "turbo -F @space-scavenger-hunt/db db:migrate",
    "db:deploy": "turbo -F @space-scavenger-hunt/db db:deploy",
    "db:local": "turbo -F @space-scavenger-hunt/db db:local"
  },
  "dependencies": {
    "@space-scavenger-hunt/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@space-scavenger-hunt/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
